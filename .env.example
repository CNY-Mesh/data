MQTT_HOST=mqtt.meshtastic.org
MQTT_PORT=1883
MQTT_USERNAME=meshdev
MQTT_PASSWORD=large4cats
MQTT_CLIENT_ID=cnymesh-12345678
MQTT_KEEPALIVE=60
MQTT_CLEAN_SESSION=1
