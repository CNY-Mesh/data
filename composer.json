{
  "name": "ben/meshtastic-mqtt-php",
  "type": "project",
  "require": {
    "php": ">=8.1",
    "php-mqtt/client": "^2.2",
    "google/protobuf": "^4.27",
    "vlucas/phpdotenv": "^5.6",
    "ext-pdo": "*",
    "ext-openssl": "*",
    "ext-json": "*"
  },
  "autoload": {
    "psr-4": {
      "App\\": "src/",
      "Meshtastic\\": "src/Protos/Meshtastic/",
      "GPBMetadata\\": "src/Protos/GPBMetadata/"
    }
  },
  "scripts": {
    "serve": "php -S 0.0.0.0:8080 -t public",
    "run": "php bin/run.php"
  }
}